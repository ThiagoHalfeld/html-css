document.addEventListener('DOMContentLoaded', function () {
    AdicionarMascaras();
});

function isNullOrWhitespace(input) {

    if (typeof input === 'undefined' || input == null) return true;

    return input.replace(/\s/g, '').length < 1;
}

function TestaCPF(strCPF) {
    var Soma;
    var Resto;
    Soma = 0;
    if (strCPF == "00000000000") return false;

    for (i = 1; i <= 9; i++) Soma = Soma + parseInt(strCPF.substring(i - 1, i)) * (11 - i);
    Resto = (Soma * 10) % 11;

    if ((Resto == 10) || (Resto == 11)) Resto = 0;
    if (Resto != parseInt(strCPF.substring(9, 10))) return false;

    Soma = 0;
    for (i = 1; i <= 10; i++) Soma = Soma + parseInt(strCPF.substring(i - 1, i)) * (12 - i);
    Resto = (Soma * 10) % 11;

    if ((Resto == 10) || (Resto == 11)) Resto = 0;
    if (Resto != parseInt(strCPF.substring(10, 11))) return false;
    return true;
}

function TestaEmail(email) {
    const re = /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
    return re.test(String(email).toLowerCase());
}

function TestaTel(tipoTel, Tel) {    
    if (isNullOrWhitespace(tipoTel) || isNullOrWhitespace(Tel)) {
        return false;
    }
    var validator = true;
    var primeiroNumCel = Tel.substr(3, 1);
    var primeiroNumTel = Tel.substr(2, 1);
    if (tipoTel == 3) {
        if (Tel.length != 11) {
            validator = false;
        } else if (Tel.substr(2, 1) != 9) {
            validator = false;
        } else if (primeiroNumCel != 9 && primeiroNumCel != 8 && primeiroNumCel != 7 && primeiroNumCel != 6) {
            validator = false;
        }
    } else {
        if (Tel.length != 10) {
            validator = false;
        } else if (primeiroNumTel == 9 || primeiroNumTel == 8 || primeiroNumTel == 7 || primeiroNumTel == 6) {
            validator = false;
        }
    }
    return validator;
}

function AdicionarMascaras() {
    $('.maskData').mask('99/99/9999');
    $('.maskTelefone').mask('(99) 9999-9999');
    $('.maskCelular').mask('(99) 99999-9999');
    $('.maskMatricula').mask('99999999-99');
    $('.maskCPF').mask('999.999.999-99');
    $('.maskCEP').mask('99999-999');
    $('.maskUF').mask('AA', {
        translation: {
            A: { pattern: /^[A-Za-záàâãéèêíïóôõöúçñÁÀÂÃÉÈÍÏÓÔÕÖÚÇÑ'\s]+$/g, recursive: true },
        },
    });

    $('.masKSomenteNumberos').mask('#', {
        reverse: true
    });
}